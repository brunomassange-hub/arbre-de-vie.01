{
  "name": "Activity",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nom de l'activit\u00e9"
    },
    "branch": {
      "type": "string",
      "enum": [
        "Social",
        "Physique",
        "Intellectuel",
        "\u00c9motionnel",
        "Artistique",
        "Spirituel"
      ],
      "description": "La branche concern\u00e9e"
    },
    "description": {
