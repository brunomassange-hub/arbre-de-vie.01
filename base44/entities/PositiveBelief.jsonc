{
  "name": "PositiveBelief",
  "type": "object",
  "properties": {
    "branch": {
      "type": "string",
      "enum": [
        "Social",
        "Physique",
        "Intellectuel",
        "\u00c9motionnel",
        "Artistique",
        "Spirituel"
      ],
      "description": "La branche concern\u00e9e"
    },
    "belief": {
      "type": "string",
      "description": "La croyance positive"
    },
    "age": {
      "type": "number",
      "description": "\u00c2ge auquel cette croyance s'est form\u00e9e"
    },
    "note": {
      "type": "string",
      "description": "Note ou contexte suppl\u00e9mentaire"
    }
  },
  "required": [
    "branch",
    "belief"
  ],
  "rls": {
    "create": true,
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}